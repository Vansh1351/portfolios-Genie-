{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "(.*)",
      "destination": "/"
    }
  ]
}
