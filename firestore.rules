rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId)
        && incoming().keys().hasAll(['profile_data', 'sessions_data', 'exports_data', 'settings', 'updated_at'])
        && incoming().updated_at == request.time;
      allow update: if isOwner(userId) && isValidId(userId)
        && incoming().updated_at == request.time
        && incoming().updated_at >= existing().updated_at;
      
      allow list: if false;
    }
  }
}
